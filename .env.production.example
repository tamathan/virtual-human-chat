# Production Environment Variables Template
# Copy this to .env.production and fill in your actual values

# Frontend Environment Variables
VITE_BFF_URL=https://your-project-id.web.app

# Backend Environment Variables (for BFF deployment)
# IMPORTANT: Use Google Secret Manager for these in production
GEMINI_API_KEY=AIza...your_actual_gemini_api_key_here
JWT_SECRET=your_secure_jwt_secret_minimum_256_bits_base64_encoded_recommended

# Token Configuration (Production Settings)
TOKEN_TTL_SEC=1800
TOKEN_CONNECT_WINDOW_SEC=60

# Environment
NODE_ENV=production

# CORS Configuration (Production Domain)
FRONTEND_URL=https://your-project-id.web.app

# Google Cloud Configuration
GCP_PROJECT_ID=your-google-cloud-project-id
GCP_REGION=asia-northeast1

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id

# Security Configuration
HSTS_MAX_AGE=31536000
CSP_REPORT_URI=https://your-domain.com/csp-report

# Monitoring & Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Performance Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TOKEN_RATE_LIMIT_MAX=3

# Cloud Run Configuration
SERVICE_NAME=vh-bff
CLOUD_RUN_MEMORY=512Mi
CLOUD_RUN_CPU=1
CLOUD_RUN_MAX_INSTANCES=10
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_CONCURRENCY=1000
CLOUD_RUN_TIMEOUT=300

# Custom Domain (Optional)
# CUSTOM_DOMAIN=your-custom-domain.com
# SSL_CERTIFICATE_TYPE=managed