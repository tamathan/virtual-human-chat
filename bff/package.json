{
  "name": "virtual-human-bff",
  "version": "1.0.0",
  "description": "Backend for Frontend for Virtual Human Chat",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node server.js",
    "dev": "tsx watch src/server.ts",
    "docker:build": "docker build -t vh-bff .",
    "docker:run": "docker run -p 8080:8080 vh-bff"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.4",
    "tsx": "^4.6.2"
  }
}